{ 
  "pyprland": {
    "plugins": [
      "scratchpads"
    ]
  },
  "scratchpads": {
    "term": {
      "command": "alacritty --class dropterm",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36
    },
    "vpn": {
      "command": "/opt/cisco/anyconnect/bin/vpnui",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36,
      "lazy": true
    },
    "spotify": {
      "command": "spotify",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36,
      "lazy": true
    },
    "network_manager": {
      "command": "nm-connection-editor",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36,
      "lazy": true
    },
    "audio": {
      "command": "pavucontrol",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36,
      "lazy": true
    },
    "sysmonitor": {
      "command": "alacritty --class sysmonitor -e btop",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36,
      "lazy": true
    },
    "ranger": {
      "command": "alacritty --class sysmonitor -e ranger",
      "animation": "fromTop",
      "unfocus": "hide",
      "margin": 36,
      "lazy": true
    }
  }
}
